// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql" // We are configuring this for PostgreSQL
}

enum Role {
  REQUESTER
  APPROVER
}

enum DocStatus {
  REQUEST
  CHECKING
  APPROVED
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String?    // <-- Added to store encrypted passwords
  role      Role       @default(REQUESTER)
  documents Document[]
}

model Document {
  id           String    @id @default(cuid())
  subject      String
  docNumber    String    @unique
  amount       Float
  status       DocStatus @default(REQUEST)
  rejectReason String?
  fileName     String?   // <-- Added to store the file name
  fileData     String?   // <-- Added to store the actual file content
  createdAt    DateTime  @default(now())
  deadline     DateTime
  userId       String
  user         User      @relation(fields: [userId], references: [id])
}
// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql" // We are configuring this for PostgreSQL
}

enum Role {
  REQUESTER
  APPROVER
}

enum DocStatus {
  REQUEST
  CHECKING
  APPROVED
  PAID // <-- Added new status
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String?
  role      Role       @default(REQUESTER)
  documents Document[]
}

model Document {
  id            String    @id @default(cuid())
  customerName  String // <-- Added for customer tracking
  subject       String
  docNumber     String    @unique
  amount        Float
  status        DocStatus @default(REQUEST)
  rejectReason  String?
  fileName      String?
  fileData      String?
  proofFileName String?
  proofFileData String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt // <-- Automatically updates on any change
  deadline      DateTime
  userId        String
  user          User      @relation(fields: [userId], references: [id])
}
